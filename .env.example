# Database
DATABASE_URL=postgresql://neuralflow:YOUR_PASSWORD@postgres:5432/reservations_db

# Redis
REDIS_URL=redis://redis-n8n:6379/2

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# External Services (for Phase 2+)
WHISPER_API_URL=http://whisper-asr:8000
RASA_API_URL=http://rasa-nlu:5005
OPENWA_API_URL=http://openwa-whatsapp:3002

# App
NODE_ENV=production
PORT=3000

# Restaurant Configuration
# El UUID del restaurante principal (genera uno nuevo con: uuidgen)
RESTAURANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# Pexels API
PEXELS_API_KEY=your_pexels_api_key_here

# Voice Bot (Pipecat)
NEXT_PUBLIC_PIPECAT_URL=https://voicebot.neuralflow.space
# En desarrollo local: http://localhost:7860

# ──── WhatsApp (Telnyx) ────
TELNYX_API_KEY=KEY_your_telnyx_api_key
TELNYX_WHATSAPP_NUMBER=+34XXXXXXXXX
TELNYX_WABA_ID=your_whatsapp_business_account_id

# ──── Cron Jobs ────
CRON_SECRET=generate_with_openssl_rand_hex_32

# SignalWire (Telefonía - Opcional, para futura integración)
# SIGNALWIRE_PROJECT_ID=your_project_id
# SIGNALWIRE_ACCESS_TOKEN=your_access_token
# SIGNALWIRE_SPACE_URL=your_space.signalwire.com

# Voice Bridge API Key (para autenticar requests desde Pipecat)
# Genera una clave segura con: openssl rand -hex 32
VOICE_BRIDGE_API_KEY=your-generated-api-key-here

# ──── System Configuration ────
# Tamaño máximo de grupo para reservas
MAX_PARTY_SIZE=50
# Tamaño mínimo de grupo para reservas
MIN_PARTY_SIZE=1
# Duración default de reserva en minutos
DEFAULT_RESERVATION_DURATION=120
# URL pública de la app (para links en emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
